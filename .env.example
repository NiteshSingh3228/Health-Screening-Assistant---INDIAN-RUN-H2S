# ─────────────────────────────────────────────────────────────
#  Health Screening Assistant — Environment Configuration
# ─────────────────────────────────────────────────────────────

# ── AI / LLM Keys (optional — app works without them) ────────
# Set ONE of these to enable AI-generated explanations & chat:

# OpenAI GPT (recommended — supports gpt-4o-mini)
OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude (fallback if OpenAI not set)
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Backend settings ─────────────────────────────────────────
MODELS_DIR=models
DATA_FILE=data.json
PORT=8000

# ── Frontend settings ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
